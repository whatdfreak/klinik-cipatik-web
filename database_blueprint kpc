## Row Level Security (RLS) — Rekomendasi

```sql
-- Tabel publik (bisa dibaca siapa saja, tidak bisa diubah dari client)
ALTER TABLE services         ENABLE ROW LEVEL SECURITY;
ALTER TABLE doctor_schedule  ENABLE ROW LEVEL SECURITY;
ALTER TABLE staff            ENABLE ROW LEVEL SECURITY;
ALTER TABLE clinic_info      ENABLE ROW LEVEL SECURITY;
ALTER TABLE clinic_content   ENABLE ROW LEVEL SECURITY;

-- Hanya boleh SELECT (read-only untuk anonymous)
CREATE POLICY "public_read_services"    ON services        FOR SELECT USING (is_active = TRUE);
CREATE POLICY "public_read_schedule"   ON doctor_schedule  FOR SELECT USING (TRUE);
CREATE POLICY "public_read_staff"      ON staff            FOR SELECT USING (is_active = TRUE);
CREATE POLICY "public_read_clinic"     ON clinic_info      FOR SELECT USING (TRUE);
CREATE POLICY "public_read_content"    ON clinic_content   FOR SELECT USING (is_active = TRUE);

-- Tabel appointments: tidak boleh dibaca/diubah langsung dari client (hanya via Service Role di API Route)
ALTER TABLE appointments ENABLE ROW LEVEL SECURITY;
-- Tidak ada policy publik → default DENY dari client
```

